<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Qui es tu ?"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btn_profil_arthur"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Arthur"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_profil_robin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Robin"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_profil_clement"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Clément"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btn_anonyme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mode anonyme"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_retour_choix_co"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retour" />

</LinearLayout>