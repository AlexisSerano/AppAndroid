<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:layout_marginBottom="48dp">

        <Button
            android:id="@+id/btn_deconnexion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Déconnexion" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_salutation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Salut Robin !"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="on s'entraîne sur quoi aujourd'hui ?"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="48dp"/>

        <Button
            android:id="@+id/btn_go_maths"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exercice de Math"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_go_culture_g"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exercice de culture g" />

    </LinearLayout>
</LinearLayout>